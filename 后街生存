local borderEnabled = true
local COLOR_SCHEMES = {
    ["胶囊"] = {
        type = "gradient",
        colors = {
            ColorSequenceKeypoint.new(0, Capsule.DeepPurple),
            ColorSequenceKeypoint.new(0.2, Capsule.Purple),
