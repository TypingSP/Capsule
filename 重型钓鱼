task.spawn(function()
    local VirtualInputManager = game:GetService("VirtualInputManager")
    local TARGET_ANIMATIONS = {
        "rbxassetid://139310377090355",
        "rbxassetid://126829237727532",
        "rbxassetid://93648246978510"
    }
    local busy = false
    local function HookCharacter(character)
        local humanoid = character:WaitForChild("Humanoid")
        humanoid.AnimationPlayed:Connect(function(track)
            local anim = track.Animation
            if not _G.AutoSkillF then return end
            if busy then return end
            if not anim then return end
            local matched = false
            for _, id in ipairs(TARGET_ANIMATIONS) do
                if anim.AnimationId == id then
                    matched = true
                    break
                end
            end
            if matched then
                busy = true
                task.delay(_G.SkillFDelay, function()
                    VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.F, false, game)
                    task.wait(0.05)
                    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.F, false, game)
                    task.wait(1)
                    busy = false
                end)
            end
        end)
    end
    if LocalPlayer.Character then HookCharacter(LocalPlayer.Character) end
    LocalPlayer.CharacterAdded:Connect(HookCharacter)
end)

