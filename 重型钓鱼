local function UpdateWeatherUI(weather)
    if WeatherTextLabel and WeatherFrame then
        if weather then
            WeatherTextLabel.Text = "当前天气: " .. weather
        else
            WeatherTextLabel.Text = "当前天气: 未知"
        end
        local colorMap = {
            Foggy = Color3.fromRGB(150, 150, 150),
            Thunderstorm = Color3.fromRGB(30, 30, 80),
            Windy = Color3.fromRGB(100, 150, 255),
            Clear = Color3.fromRGB(255, 200, 50)
        }
        WeatherFrame.BackgroundColor3 = colorMap[weather] or Color3.fromRGB(40, 40, 40)
    end
end

